[user]
	name = Jaehaks
	email = wogkr3654@naver.com
[credential]
	helper = manager
[core]
	autocrlf = input
	editor = nvim
	quotepath = false
[alias]
	lg = log --graph --oneline --decorate --all --pretty=format:'%C(auto)%h%Creset %C(auto)%d%Creset %s %C(blue)(%cr)%Creset'
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[commit]
	verbose = true
