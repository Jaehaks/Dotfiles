# name: Show usage hint for automatic suggestions
# type: boolean
autosuggest.hint = False
# use gray text suggestion inline like before v1.9.25
autosuggest.inline = False
# suggestion list is off automatically after end of Esc / Enter
suggestionlist.autooff = False
# After v1.8.0, suggestionlist is shown instead of inline autosuggestion.
# use it default (if autosuggest.inline is true, it false) you can turn on with F2
suggestionlist.default = True

history.time_stamp        = show
match.substring           = True
fzf.default_bindings	  = True

# don't show copyright message at startup
clink.logo 				  = none
# don't show update message at startup
clink.autoupdate 		  = off

# plugin - gizmos matchicons on (except 'cd', completion shows file/dir icons)
# It shows color also. but If you integrate with fzf.lua, the colors are disabled
matchicons.enable		  = True
# plugin - gizmos tilde_autoexpand (you can use ~ as linux)
tilde.autoexpand 		  = True


###################################
# 'clink.path' to load lua setting files is declared in aliase.cmd as %CLINK_PATH%
# If there is no value of clink.path, detect %CLINK_PATH% instead of it.
